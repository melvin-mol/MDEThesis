// broadcast chan reached[N_REACTANTS];
operation Uppaal!GlobalDeclarations setupReached(): Uppaal!GlobalDeclarations {	
	var variable = variable("reached");
    variable.index.add(new Uppaal!ValueIndex());
   	variable.index.first().sizeExpression = new Uppaal!IdentifierExpression();
    variable.index.first().sizeExpression.identifier = self.findVariable("N_REACTANTS");
    
   	self.declaration.add(channelVariableDeclaration(true, "chan", variable));
	return self;
}